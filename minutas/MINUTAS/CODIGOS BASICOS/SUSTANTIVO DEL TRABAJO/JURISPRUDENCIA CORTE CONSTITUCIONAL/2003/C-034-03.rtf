\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs28\insrsid11548437 
\par Declarar }{\b\fs28\insrsid11548437 INEXEQUIBLE}{\fs28\insrsid11548437  la expresi\'f3n }{\i\fs28\insrsid11548437 \'93y no hubieren sido despedidos por justa causa\'94}{\fs28\insrsid11548437  contenida en los literales a) y b) del art\'edculo 306 del C\'f3
digo Sustantivo del Trabajo.
\par 
