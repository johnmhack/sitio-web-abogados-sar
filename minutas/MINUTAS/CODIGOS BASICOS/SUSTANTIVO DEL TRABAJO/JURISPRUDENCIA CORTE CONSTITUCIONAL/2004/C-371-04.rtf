\chftn {\footnote \pard\plain \s27\qj \li0\ri50\widctlpar\nooverflow\faroman\rin50\lin0\itap0 \fs20\lang3082\langfe3082\cgrid\langnp3082\langfenp3082 {\cs28\super\insrsid8138389 \chftn }{\insrsid8138389 
