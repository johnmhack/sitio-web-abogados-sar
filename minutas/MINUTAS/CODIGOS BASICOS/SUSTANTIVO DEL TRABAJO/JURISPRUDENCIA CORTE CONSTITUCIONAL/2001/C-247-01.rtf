\par }\pard \qj\li567\ri-1\widctlpar\adjustright {\b\fs28 LIBERTAD DE CONFIGURACION LEGISLATIVA EN SEGURIDAD SOCIAL}{\fs28 -R\'e9gimenes diferentes
