\par 
\par }\pard \qj \li0\ri0\nowidctlpar\tx3168\tx3456\faauto\rin0\lin0\itap0 {\f1\cf1\insrsid3605028 REFERENCIA\tab :\tab Proceso No. 2244
\par 
\par FECHA\tab :\tab Bogot\'e1, D. E., abril veinticinco (25) de mil novecientos
\par \tab \tab noventa y uno (1991).
\par 
\par \tab \tab Acci\'f3n de inconstitucionalidad contra el art\'edculo 1\'ba del
\par \tab \tab Decreto Extraordinario (sic) 753 del 5 de abril de 1956, 
\par \tab \tab "por  el  cual  se  sustituye  el  art\'edculo 430  del C\'f3digo
\par \tab \tab Sustantivo del Trabajo".
\par 
\par ACTORES\tab : \tab Julio   Arturo   Barrero  Arias,  Luis  Eduardo  Guti\'e9rrez 
\par \tab \tab Angarita, Luis Hernando Van-Strahlen, Rodrigo Hern\'e1n
\par \tab \tab Galarza Nanrajo. 
