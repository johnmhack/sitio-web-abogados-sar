}\pard{\qj\li3969\fi0\ri0\sb0\sl\sa0 \plain\f2\fs28\cf0 Dr. ALVARO TAFUR GALVIS\par
\qc\li0\fi0\ri0\sb0\sl\sa0\toc1 \plain\f1\fs28\cf0\b \par
