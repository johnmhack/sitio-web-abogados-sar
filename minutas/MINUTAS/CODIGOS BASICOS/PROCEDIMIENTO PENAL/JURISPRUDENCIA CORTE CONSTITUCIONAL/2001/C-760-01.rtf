\par }\pard\plain \s17\qj\ri-700\widctlpar\intbl\adjustright \i\f1\fs28\lang1034\cgrid {\f0 El Defensor del Pueblo y el Ministerio P\'fablico podr\'e1n formular querella cuando se afecte el inter\'e9s p\'fablico.
