\lang1034 \rdblquote }{\cs18\lang1034\super \chftn {\footnote \pard\plain \s19\widctlpar{\*\pn \pnlvlcont\ilvl12\ls0\pnrnot0\pndec }\ilvl12\adjustright \fs20\lang1034\cgrid {\cs18\super \chftn }{ Sentencia C - 543 de 1992.}}}{\lang1034 
