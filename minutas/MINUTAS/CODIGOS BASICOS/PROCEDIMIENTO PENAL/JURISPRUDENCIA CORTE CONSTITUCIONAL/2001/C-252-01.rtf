\par 
\par }{\b\fs28\cf1 PRINCIPIO DE FAVORABILIDAD PENAL}{\fs28\cf1 -Alcance
\par 
\par }{\b\fs28\cf1 PRINCIPIO DE FAVORABILIDAD PENAL}{\fs28\cf1 -Contenido sustancial
\par 
\par }{\b\fs28\cf1 PRINCIPIO DE FAVORABILIDAD PENAL EN CASACION}{\fs28\cf1 -Hechos con anterioridad a la vigencia
