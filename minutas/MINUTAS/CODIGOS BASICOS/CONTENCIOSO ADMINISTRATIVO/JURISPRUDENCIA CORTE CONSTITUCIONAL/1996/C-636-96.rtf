\par }\pard \qc\ri51\widctlpar\intbl\tx4536\adjustright {\fs28 Magistrado\cell }\pard \qj\ri51\widctlpar\intbl\tx4536\adjustright {\fs28             ANTONIO BARRERA CARBONELL
