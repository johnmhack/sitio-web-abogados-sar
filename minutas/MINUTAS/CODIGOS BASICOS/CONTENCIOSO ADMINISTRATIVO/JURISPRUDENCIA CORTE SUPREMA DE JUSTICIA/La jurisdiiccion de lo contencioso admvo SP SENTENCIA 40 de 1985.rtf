\par }\pard \qj \li0\ri0\sl240\slmult0\nowidctlpar\tx432\faauto\rin0\lin0\itap0 {\b\f1\cf1\insrsid5920122 MAGISTRADO PONENTE:}{\f1\cf1\insrsid5920122  doctor Manuel Gaona Cruz.
\par 
\par Aprobada por Acta n\'famero 24.
