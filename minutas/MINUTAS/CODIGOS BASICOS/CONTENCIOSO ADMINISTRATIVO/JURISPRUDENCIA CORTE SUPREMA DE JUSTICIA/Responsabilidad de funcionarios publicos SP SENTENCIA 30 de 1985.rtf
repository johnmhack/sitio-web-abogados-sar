\fs24\lang9226\langfe9226\cgrid\langnp9226\langfenp9226 {\b\f1\cf1\insrsid10363453 RESPONSABILIDAD DE LOS FUNCIONARIOS P\'daBLICOS, DE LOS DA\'d1OS QUE CAUSEN POR CULPA GRAVE O DOLO EN EL EJERCICIO DE SUS FUNCIONES. LA RESPON
SABILIDAD ANTERIOR LA DETERMINA LA JURISDICCI\'d3N DE LO CONTENCIOSO ADMINISTRATIVO SIN OLVIDO DE NINGUNO DE LOS ELEMENTOS DEL DEBIDO PROCESO. DEL DERECHO DE DEFENSA.
