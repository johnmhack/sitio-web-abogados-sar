\par 
\par 1.1. Art\'edculo 4\'b0 }{\rtlch\fcs1 \af0\afs28 \ltrch\fcs0 \cgrid0\insrsid13113055\charrsid5663188 de {\*\xmlopen\xmlns2{\factoidname PersonName}{\xmlattr\xmlattrns0{\xmlattrname ProductID}{\xmlattrvalue la Ley}}}la Ley{\*\xmlclose} 1653 de 2013}{
\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid13113055\charrsid5663188 
