\par }\pard\plain \ltrpar\s27\qj \li3402\ri51\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin51\lin3402\itap0\pararsid4731646 \rtlch\fcs1 \af0\afs24\alang1025 \ltrch\fcs0 \fs24\lang9226\langfe9226\cgrid\langnp9226\langfenp9226 {\rtlch\fcs1 
