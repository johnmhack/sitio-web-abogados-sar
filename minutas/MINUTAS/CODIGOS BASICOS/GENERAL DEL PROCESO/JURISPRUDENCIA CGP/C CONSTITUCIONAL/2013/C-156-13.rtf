PersonName}{\xmlattr\xmlattrns0{\xmlattrname ProductID}{\upr{\xmlattrvalue LA NACI?N}{\*\ud{\xmlattrvalue LA NACI\u-45 ?N}}}}}LA NACI\'d3N{\*\xmlclose}
