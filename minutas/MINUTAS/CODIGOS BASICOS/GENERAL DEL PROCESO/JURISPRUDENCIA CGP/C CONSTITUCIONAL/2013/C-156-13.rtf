\par }\pard \ltrpar\qj \li680\ri680\nowidctlpar\wrapdefault\faauto\rin680\lin680\itap0\pararsid15742147 {\rtlch\fcs1 \af0\afs24 \ltrch\fcs0 \fs28\lang3082\langfe3082\langnp3082\insrsid3306856\charrsid15742147 \'933.2. Visto as\'ed, se produjo una }{
