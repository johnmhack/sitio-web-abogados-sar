\i\f1\fs24\insrsid13452540\charrsid13452540 RATIFICACI\'d3N DE TESTIMONIOS RECIBIDOS FUERA DEL PROCESO}{\rtlch\fcs1 \af1\afs24 \ltrch\fcs0 \f1\fs24\insrsid13452540\charrsid13452540 . Solo podr\'e1
