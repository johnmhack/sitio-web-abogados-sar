\par 
\par 1}{\rtlch\fcs1 \ai\af1\afs24 \ltrch\fcs0 \i\f1\fs24\insrsid13452540\charrsid13452540 . }{\rtlch\fcs1 \af1\afs24 \ltrch\fcs0 \f1\fs24\insrsid13452540\charrsid13452540 La tendr\'e1
