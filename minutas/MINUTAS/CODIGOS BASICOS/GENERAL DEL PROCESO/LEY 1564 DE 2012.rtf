\par DISPOSICIONES ESPECIALES PARA LA EFECTIVIDAD DE LA GARANT\'cdA REAL.}{\rtlch\fcs1 \ab\af1\afs24 \ltrch\fcs0 \b\f1\fs24\insrsid13452540\charrsid13452540  
